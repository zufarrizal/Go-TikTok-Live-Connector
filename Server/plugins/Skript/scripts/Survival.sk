# Summon wither lewat command execute di posisi pemain.
command /wither <number> <text> <number>:
    trigger:
        set {_total} to arg-1 * arg-3
        loop all players:
            set {_p} to loop-player
            send title "&4&l%arg-2%" with subtitle "&8&lSUMMON &7Wither &ex%{_total}%" to loop-player
            loop {_total} times:
                play sound "entity.experience_orb.pickup" to loop-player
                execute console command "execute at %{_p}% run summon minecraft:wither ~ ~1 ~"
                wait 2 ticks

