# dm {value} {username} {repeat}
# Memberikan diamond ke semua pemain berdasarkan hasil perkalian nilai dan repeat.
command /dm <number> <text> <number> :
    trigger:
        set {_total} to arg-1 * arg-3
        send title "&6&l%arg-2%" with subtitle "&b&lGIVE &e%{_total}% &fDiamonds" to players
        loop all players:
            play sound "entity.experience_orb.pickup" to loop-player
            give {_total} of diamond to loop-player

# Memberikan enchanted golden apple ke semua pemain.
command /ega <number> <text> <number> :
    trigger:
        set {_total} to arg-1 * arg-3
        send title "&6&l%arg-2%" with subtitle "&d&lGIVE &6%{_total}% &eEnchanted Golden Apples" to players
        loop all players:
            play sound "entity.experience_orb.pickup" to loop-player
            give {_total} of enchanted golden apple to loop-player

# summon commands: {value} {username} {repeat}
# Setiap command di bawah menghitung total spawn lalu memunculkan mob di dekat semua pemain.
command /chicken <number> <text> <number>:
    trigger:
        set {_total} to arg-1 * arg-3
        loop all players:
            set {_loc} to location of loop-player
            add 1 to y-coordinate of {_loc}
            send title "&6&l%arg-2%" with subtitle "&a&lSUMMON &fChicken &ex%{_total}%" to loop-player
            loop {_total} times:
                play sound "entity.experience_orb.pickup" to loop-player
                spawn 1 chicken at {_loc}
                wait 2 ticks

